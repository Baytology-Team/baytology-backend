{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "JwtSettings": {
    "Secret": "",
    "Issuer": "Baytology.Api",
    "Audience": "Baytology.Clients",
    "AccessTokenExpirationInMinutes": 30,
    "RefreshTokenExpirationInDays": 7
  },
  "AppSettings": {
    "CorsPolicyName": "Baytology"
  },
  "StartupInitialization": {
    "Enabled": true,
    "SeedPropertyCsvOnStartup": false
  },
  "Email": {
    "DeliveryMode": "FilePickup",
    "PickupDirectory": "runtime-logs/emails",
    "FromAddress": "no-reply@baytology.local",
    "FromDisplayName": "Baytology"
  },
  "AdminSettings": {
    "DefaultEmail": "",
    "DefaultPassword": ""
  },
  "GoogleAuthSettings": {
    "ClientId": "",
    "ClientSecret": ""
  },
  "Paymob": {
    "EnableLocalSimulation": false,
    "ApiKey": "",
    "SecretKey": "",
    "PublicKey": "",
    "BaseUrl": "https://accept.paymob.com/v1/intention/",
    "IntegrationId": 0,
    "WebhookToken": "",
    "WebhookTokenHeaderName": "X-Webhook-Token",
    "WebhookTokenQueryParameterName": "token"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}
